# ── Stripe ──────────────────────────────────────────
# Get your keys at https://dashboard.stripe.com/apikeys
# Use pk_test_... for development, pk_live_... for production
# NEVER put your secret key (sk_...) in this file
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY

# ── Backend API ──────────────────────────────────────
# Uncomment and set this to switch from mock data to a real API
# REACT_APP_API_URL=https://api.yoursite.com/v1

# ── App ──────────────────────────────────────────────
# Optional: override the default app name
# REACT_APP_NAME=Artelier
